---
import { getEntry } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  navDark?: boolean;
}

const settings = await getEntry('settings', 'global');
const site = settings.data;

const {
  title = `${site.siteName} ${site.propertyName} — Maasai Mara, Kenya`,
  description = 'Perched on a graceful bend of the Mara River at the foot of the Oloololo Escarpment. Authentic safari experiences where nature leads.',
  ogImage,
  canonicalUrl = Astro.url.pathname,
  navDark = false,
} = Astro.props;

const fullCanonicalUrl = `https://exloreansmararivercamp.netlify.app${canonicalUrl}`;
const fullOgImage = ogImage ? (ogImage.startsWith('http') ? ogImage : `https://exloreansmararivercamp.netlify.app${ogImage}`) : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  
  <!-- Canonical URL -->
  <link rel="canonical" href={fullCanonicalUrl} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {fullOgImage && <meta property="og:image" content={fullOgImage} />}
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={fullCanonicalUrl} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  {fullOgImage && <meta property="twitter:image" content={fullOgImage} />}
  
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>

  <!-- Navigation -->
  <nav class={`nav ${navDark ? 'nav-dark' : ''}`} id="mainNav">
    <a href="/" class="nav-brand">
      {site.logo ? (
        <img src={site.logo} alt={site.siteName} class="nav-logo-img" />
      ) : (
        site.siteName
      )}
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#camp">The Camp</a></li>
      <li><a href="#stay">Stay</a></li>
      <li><a href="#when-to-visit">When to Visit</a></li>
      <li><a href="#experiences">Experiences</a></li>
      <li><a href="#journal">Journal</a></li>
      <li><a href="/contact">Contact Us</a></li>
    </ul>
    <div class="nav-actions">
      <a href={site.bookingUrl} class="nav-cta" target="_blank" rel="noopener">Book Now</a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <slot />

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-grid">
      <div>
        <div class="footer-logo">{site.siteName}</div>
        <div class="footer-subtitle">{site.propertyName} · Kenya</div>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>The Camp</h4>
          <a href="#camp">Our Story</a>
          <a href="#camp">Location</a>
        </div>
        <div class="footer-col">
          <h4>Stay</h4>
          <a href="#stay">River Tents</a>
          <a href="#stay">Bush Tents</a>
          <a href="#stay">Simba's Den</a>
        </div>
        <div class="footer-col">
          <h4>Explore</h4>
          <a href="#when-to-visit">When to Visit</a>
          <a href="#experiences">Game Drives</a>
          <a href="#journal">Journal</a>
        </div>
      </div>
      <div class="footer-managed">
        <div class="footer-managed-label">Managed by</div>
        <div class="footer-managed-name">Planhotel<br>Hospitality Group</div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 {site.siteName} · Planhotel Hospitality Group</span>
      <div class="lang-switcher">
        <a href="#"><strong>EN</strong></a>
        <a href="#">DE</a>
        <a href="#">IT</a>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const nav = document.getElementById('mainNav');
      const navToggle = document.getElementById('navToggle');
      const navLinks = document.getElementById('navLinks');
      
      if (!navToggle || !navLinks) {
        console.error('Mobile menu elements not found');
        return;
      }
      
      console.log('Mobile menu initialized');
      
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('scrolled', window.scrollY > 80);
      });
      
      navToggle.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        this.classList.toggle('active');
        navLinks.classList.toggle('active');
        console.log('Menu toggled:', navLinks.classList.contains('active'));
      });
      
      // Close menu when clicking a link
      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          navToggle.classList.remove('active');
          navLinks.classList.remove('active');
        });
      });
      
      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!nav.contains(e.target) && navLinks.classList.contains('active')) {
          navToggle.classList.remove('active');
          navLinks.classList.remove('active');
        }
      });
    });
  </script>
</body>
</html>
