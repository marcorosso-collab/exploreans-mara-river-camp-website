---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

// Generate static paths for all journal posts
export async function getStaticPaths() {
  const posts = await getCollection('journal', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Base title={`${post.data.title} — Journal`} description={post.data.description} navDark={true}>
  <article class="journal-article">
    <div class="container">
      <!-- Article Header -->
      <header class="article-header">
        <div class="article-meta">
          <span class="article-category">{post.data.category}</span>
          <span class="article-date">{post.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
        </div>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
      </header>

      <!-- Article Image -->
      {post.data.image && (
        <div class="article-image">
          <img src={post.data.image} alt={post.data.title} />
        </div>
      )}

      <!-- Article Body -->
      <div class="article-body">
        <Content />
      </div>

      <!-- Back to Journal -->
      <div class="article-footer">
        <a href="/#journal" class="btn-secondary">← Back to Journal</a>
      </div>
    </div>
  </article>
</Base>

<style>
  .journal-article {
    padding: 120px 0 80px;
    background: var(--sand-light);
    min-height: 100vh;
  }
  
  .article-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 48px;
  }
  
  .article-meta {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 24px;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mara-charcoal);
  }
  
  .article-category {
    color: var(--ochre);
    font-weight: 500;
  }
  
  .article-date {
    color: var(--warm-stone);
  }
  
  .article-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 400;
    line-height: 1.15;
    color: var(--mara-black);
    margin-bottom: 24px;
  }
  
  .article-description {
    font-size: 18px;
    line-height: 1.6;
    color: var(--mara-charcoal);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .article-image {
    margin: 48px -48px;
    max-width: calc(100% + 96px);
  }
  
  .article-image img {
    width: 100%;
    height: 500px;
    object-fit: cover;
  }
  
  .article-body {
    max-width: 720px;
    margin: 64px auto;
    font-size: 17px;
    line-height: 1.8;
    color: var(--mara-charcoal);
  }
  
  .article-body :global(h2) {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--mara-black);
    margin: 48px 0 24px;
  }
  
  .article-body :global(h3) {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    color: var(--mara-black);
    margin: 36px 0 16px;
  }
  
  .article-body :global(p) {
    margin-bottom: 20px;
  }
  
  .article-body :global(strong) {
    color: var(--mara-black);
    font-weight: 500;
  }
  
  .article-footer {
    text-align: center;
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  
  .btn-secondary {
    display: inline-block;
    padding: 14px 28px;
    border: 1px solid var(--mara-charcoal);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mara-charcoal);
    transition: all 0.3s ease;
  }
  
  .btn-secondary:hover {
    background: var(--mara-charcoal);
    color: var(--white);
  }
  
  @media (max-width: 768px) {
    .journal-article {
      padding: 100px 0 60px;
    }
    
    .article-image {
      margin: 32px -20px;
      max-width: calc(100% + 40px);
    }
    
    .article-image img {
      height: 300px;
    }
    
    .article-body {
      font-size: 16px;
    }
  }
</style>